# Render Environment Variables
# Copy these to Render.com dashboard → Environment

# Database (Render sets this automatically)
DATABASE_URL=postgresql://user:pass@host:5432/question_bank

# frellmapi — choose ONE option:

# Option A: ngrok tunnel (quick, free tier)
# 1. Install ngrok: https://ngrok.com/download
# 2. Run: ngrok http 3001
# 3. Copy the https://xxxx.ngrok.io URL below:
FRELLMAPI_URL=https://xxxx.ngrok-free.app/v1
FRELLMAPI_KEY=freellmapi-a4fc69d7fa5ca8504930131b70d7b0cfdf6d0b09abe941ce

# Option B: Deploy frellmapi on Render as separate service
# (see frellmapi-render/ folder)
FRELLMAPI_URL=https://frellmapi-proxy.onrender.com/v1
FRELLMAPI_KEY=freellmapi-a4fc69d7fa5ca8504930131b70d7b0cfdf6d0b09abe941ce

# Option C: Use OpenRouter directly (no frellmapi needed)
# Sign up at https://openrouter.ai
FRELLMAPI_URL=https://openrouter.ai/api/v1
FRELLMAPI_KEY=sk-or-v1-xxxx

# Python version
PYTHON_VERSION=3.11
